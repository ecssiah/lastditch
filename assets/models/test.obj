# Simple capsule (low poly)
o Capsule

# --- Vertices ---

# Top hemisphere (4 rings)
v 0 1 0
v 0.707 0.707 0
v 0 0.707 0.707
v -0.707 0.707 0
v 0 -0.707 0.707

# Bottom hemisphere mirrored
v 0 -1 0
v 0.707 -0.707 0
v 0 -0.707 -0.707
v -0.707 -0.707 0
v 0 0.707 -0.707

# Cylinder ring top
v 1 0.5 0
v 0 0.5 1
v -1 0.5 0
v 0 0.5 -1

# Cylinder ring bottom
v 1 -0.5 0
v 0 -0.5 1
v -1 -0.5 0
v 0 -0.5 -1

# --- Faces ---

# Top cap
f 1 2 3
f 1 3 4
f 1 4 5
f 1 5 2

# Bottom cap
f 6 7 8
f 6 8 9
f 6 9 10
f 6 10 7

# Cylinder sides
f 11 12 16
f 11 16 15

f 12 13 17
f 12 17 16

f 13 14 18
f 13 18 17

f 14 11 15
f 14 15 18

# Connect top hemisphere to cylinder
f 2 11 12
f 3 12 13
f 4 13 14
f 5 14 11

# Connect bottom hemisphere
f 7 15 16
